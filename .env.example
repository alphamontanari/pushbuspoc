PORT=3000

# POC DE CAMPO: telemetria real obrigatória por padrão.
# O servidor consulta a FLITS/Cittati e NÃO cai para mock automaticamente.
ALLOW_MOCK=false

# Atualização das telas/endpoints
POLL_INTERVAL_SECONDS=5
STALE_AFTER_SECONDS=90

# Linha monitorada
LINE_CODE=01A
LINE_CODE_ALT=001A
STRICT_LINE_FILTER=true

# API Cittati/FLITS
CITTATI_BASE_URL=https://flits.cittati.com.br
CITTATI_APP_CODE=200
CITTATI_CLIENT_ID=1
CITTATI_COMPANY_ID=
CITTATI_USERNAME=
CITTATI_PASSWORD=
CITTATI_TOKEN=

# Recomendado para teste de campo: informe o(s) carro(s) real(is) da Linha 001A.
# Exemplo: DEFAULT_VEHICLES=26002,26003
DEFAULT_VEHICLES=

# Opcional, se a API aceitar filtro de linhas por ID numérico.
DEFAULT_LINES=
